/* Chat view styles */

ChatView {
    background: #1a1a2e;
    color: #e0e0e0;
}

#chat-header {
    dock: top;
    width: 100%;
    height: 3;
    background: #0e0e1a;
    color: #4ecca3;
    text-style: bold;
    content-align: center middle;
    border-bottom: solid #333333;
}

#message-container {
    width: 100%;
    height: 1fr;
    background: #1a1a2e;
    scrollbar-background: #1a1a2e;
    scrollbar-color: #333333;
    padding: 0;
}

MessageLine {
    width: 100%;
    height: auto;
    padding: 0 1;
}

#message-input {
    dock: bottom;
    width: 100%;
    height: 3;
    background: #0e0e1a;
    color: #e0e0e0;
    border: none;
    border-top: solid #333333;
    padding: 0 1;
}

#message-input:focus {
    border-top: solid #4ecca3;
}
