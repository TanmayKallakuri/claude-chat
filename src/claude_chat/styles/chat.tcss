#chat-header {
    dock: top;
    width: 100%;
    height: 1;
    background: #1e1e1e;
    color: #888888;
    content-align: left middle;
    padding: 0 1;
}

#message-container {
    width: 100%;
    height: 1fr;
    background: #191919;
    scrollbar-background: #191919;
    scrollbar-color: #333333;
    padding: 0;
}

MessageLine {
    width: 100%;
    height: auto;
    padding: 0 1;
}

#message-input {
    dock: bottom;
    width: 100%;
    height: 5;
    max-height: 10;
    background: #252525;
    color: #d4d4d4;
    border: tall #333333;
}

#message-input:focus {
    border: tall #666666;
}

#empty-chat {
    color: #666666;
    padding: 1;
}
