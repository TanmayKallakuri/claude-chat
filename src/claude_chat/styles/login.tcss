#login-container {
    align: center middle;
    width: 50;
    height: auto;
    padding: 1 2;
}

#title {
    text-align: center;
    color: #888888;
    width: 100%;
    margin-bottom: 1;
}

#mode-toggle {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

#mode-toggle Button {
    min-width: 12;
    margin-right: 1;
}

.field-label {
    margin-top: 1;
    color: #888888;
}

#btn-submit {
    margin-top: 1;
    width: 100%;
}

#passphrase-warning {
    margin-top: 1;
    color: #cc7700;
}

#status {
    margin-top: 1;
    color: #888888;
}
