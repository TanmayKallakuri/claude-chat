TabbedContent {
    background: #191919;
}

TabPane {
    background: #191919;
    padding: 0;
}

ContentSwitcher {
    background: #191919;
}

Tabs {
    background: #1e1e1e;
    dock: top;
}

Tab {
    background: #1e1e1e;
    color: #888888;
    padding: 0 2;
}

Tab.-active {
    color: #d4d4d4;
    text-style: bold;
}

Tab:hover {
    color: #d4d4d4;
}

OptionList {
    background: #191919;
    color: #d4d4d4;
    scrollbar-background: #191919;
    scrollbar-color: #333333;
}

OptionList > .option-list--option-highlighted {
    background: #252525;
    color: #d4d4d4;
}

Header {
    background: #1e1e1e;
    color: #888888;
}

Footer {
    background: #1e1e1e;
    color: #666666;
}
